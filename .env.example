# LINE Messaging API（LINE Bot / app.py 用）
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Notion（分析結果を議事録 DB に保存する場合）
NOTION_API_KEY=
# 省略時は 7892876a-3b90-4614-b90f-8dc426e129a5
# NOTION_DATABASE_ID=
