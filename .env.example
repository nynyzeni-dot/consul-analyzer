# このファイルをコピーして .env にリネームし、値を設定してください。

# Claude API（CLI・LINE 共通）
ANTHROPIC_API_KEY=
# 省略時は claude-sonnet-4-5
# ANTHROPIC_MODEL=claude-sonnet-4-5

# LINE Messaging API（LINE Bot / app.py 用）
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Notion（分析結果を議事録 DB に保存する場合）
NOTION_API_KEY=
# 省略時はコード内の既定 ID。Railway では Variables の NOTION_DATABASE_ID が最優先で上書きする。
# NOTION_DATABASE_ID=
